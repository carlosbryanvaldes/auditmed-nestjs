{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "api/handler.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/dist/**", "backend/node_modules/.prisma/**", "backend/node_modules/@prisma/client/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "/api/handler.js" },
    { "src": "/health",    "dest": "/api/handler.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",      "dest": "/index.html" }
  ]
}
