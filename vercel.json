{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && npm install && npx prisma generate && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/handler.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/health",      "destination": "/api/handler.js" },
    { "source": "/api/:path*",  "destination": "/api/handler.js" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
