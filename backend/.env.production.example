# Variables de entorno para producción en Vercel
# Configurar estas en el dashboard de Vercel (Settings → Environment Variables)

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="cambiar-por-secreto-largo-aleatorio-minimo-32-chars"
JWT_EXPIRES_IN="8h"
NODE_ENV="production"
CORS_ORIGIN="https://auditmed-frontend.vercel.app"
