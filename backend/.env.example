# ── Database ──────────────────────────────────────────────────────────────────
# Hostinger MySQL format:
# mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME
DATABASE_URL="mysql://user:password@localhost:3306/auditmed"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-seguro-en-produccion"
JWT_EXPIRES_IN="8h"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción: tu dominio exacto, ej: https://auditmed.tudominio.com
# En desarrollo: http://localhost:5173
CORS_ORIGIN="http://localhost:5173"
