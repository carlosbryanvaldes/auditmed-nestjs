generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  status       String   @default("ACTIVE")
  roleId       Int      @map("role_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role       Role        @relation(fields: [roleId], references: [id])
  auditCases AuditCase[]

  // Bitácora de Internos — back-references (requeridas por Prisma)
  bitacoras        Bitacora[]
  usuariosBitacora UsuarioBitacora[]
  eventosPaciente  EventoPaciente[]

  @@index([roleId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  module      String   @default("general")
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UnidadEjecutora {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?  @unique
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditCases AuditCase[]

  @@map("unidades_ejecutoras")
}

model FormTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  version     String   @default("1.0")
  formType    String?  @map("form_type")
  status      String   @default("DRAFT")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdById Int?     @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections   FormSection[]
  auditCases AuditCase[]

  @@index([isActive])
  @@map("form_templates")
}

model FormSection {
  id          Int      @id @default(autoincrement())
  templateId  Int      @map("template_id")
  title       String
  description String?
  orderIndex  Int      @default(0) @map("order_index")
  weight      Float    @default(1.0)
  createdAt   DateTime @default(now()) @map("created_at")

  template FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields   FormField[]

  @@index([templateId])
  @@map("form_sections")
}

model FormField {
  id             Int      @id @default(autoincrement())
  sectionId      Int      @map("section_id")
  label          String
  fieldKey       String   @map("field_key")
  fieldType      String   @default("YES_NO_NA") @map("field_type")
  required       Boolean  @default(true)
  hasObservation Boolean  @default(false) @map("has_observation")
  score          Float    @default(1.0)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  section   FormSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  options   FormFieldOption[]
  responses AuditResponse[]

  @@index([sectionId])
  @@map("form_fields")
}

model FormFieldOption {
  id        Int    @id @default(autoincrement())
  fieldId   Int    @map("field_id")
  label     String
  value     String
  sortOrder Int    @default(0) @map("sort_order")

  field FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
  @@map("form_field_options")
}

model AuditCase {
  id                   Int       @id @default(autoincrement())
  caseNumber           String    @unique @map("case_number")
  auditDate            String    @map("audit_date")
  status               String    @default("DRAFT")
  formTemplateId       Int       @map("form_template_id")
  unidadEjecutoraId    Int?      @map("unidad_ejecutora_id")
  auditorId            Int       @map("auditor_id")
  historiaClinicaNum   String?   @map("historia_clinica_num")
  patientHash          String?   @map("patient_hash")
  diagnosisCie10       String?   @map("diagnosis_cie10")
  diagnosisDescription String?   @map("diagnosis_description")
  generalObservations  String?   @map("general_observations")
  totalItems           Int?      @map("total_items")
  compliantItems       Int?      @map("compliant_items")
  compliancePercentage Float?    @map("compliance_percentage")
  globalRating         String?   @map("global_rating")
  auditorSignature     String?   @map("auditor_signature")
  signedAt             DateTime? @map("signed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  closedAt             DateTime? @map("closed_at")

  formTemplate    FormTemplate     @relation(fields: [formTemplateId], references: [id])
  unidadEjecutora UnidadEjecutora? @relation(fields: [unidadEjecutoraId], references: [id])
  auditor         User             @relation(fields: [auditorId], references: [id])
  responses       AuditResponse[]

  @@index([auditorId])
  @@index([status])
  @@index([formTemplateId])
  @@map("audit_cases")
}

model AuditResponse {
  id               Int      @id @default(autoincrement())
  caseId           Int      @map("case_id")
  fieldId          Int      @map("field_id")
  value            String?
  observation      String?
  conformityResult String?  @map("conformity_result")
  createdAt        DateTime @default(now()) @map("created_at")

  case  AuditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  field FormField @relation(fields: [fieldId], references: [id])

  @@unique([caseId, fieldId])
  @@index([caseId])
  @@map("audit_responses")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO: Bitácora de Internos
// Nota: UnidadEjecutora ya existe para Auditmed Pro.
//       Este módulo usa SedeClinica (tabla sedes_clinicas) — entidad independiente.
// ─────────────────────────────────────────────────────────────────────────────

model SedeClinica {
  id          String   @id @default(cuid())
  nombre      String
  latitud     Float
  longitud    Float
  radioMetros Int      @default(200) @map("radio_metros")
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  servicios        Servicio[]
  bitacoras        Bitacora[]
  usuariosBitacora UsuarioBitacora[]

  @@map("sedes_clinicas")
}

model Servicio {
  id        String      @id @default(cuid())
  nombre    String
  activo    Boolean     @default(true)
  sedeId    String      @map("sede_id")
  sede      SedeClinica @relation(fields: [sedeId], references: [id])
  createdAt DateTime    @default(now()) @map("created_at")

  bitacoras Bitacora[]

  @@map("servicios_bitacora")
}

model UsuarioBitacora {
  id          String      @id @default(cuid())
  userId      Int         @map("user_id")
  sedeId      String      @map("sede_id")
  rolBitacora RolBitacora @default(INTERNO) @map("rol_bitacora")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User        @relation(fields: [userId], references: [id])
  sede SedeClinica @relation(fields: [sedeId], references: [id])

  @@unique([userId, sedeId])
  @@map("usuarios_bitacora")
}

model Bitacora {
  id               String         @id @default(cuid())
  fecha            DateTime       @default(now())
  turno            TurnoBitacora
  supervisor       String
  medicoUserId     Int            @map("medico_user_id")
  sedeId           String         @map("sede_id")
  servicioId       String         @map("servicio_id")
  estado           EstadoBitacora @default(ABIERTA)
  latitudApertura  Float?         @map("latitud_apertura")
  longitudApertura Float?         @map("longitud_apertura")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt     @map("updated_at")

  medico   User             @relation(fields: [medicoUserId], references: [id])
  sede     SedeClinica      @relation(fields: [sedeId], references: [id])
  servicio Servicio         @relation(fields: [servicioId], references: [id])
  pacientes PacienteBitacora[]

  @@index([medicoUserId])
  @@index([sedeId])
  @@index([estado])
  @@map("bitacoras")
}

model PacienteBitacora {
  id                String         @id @default(cuid())
  documentoHash     String         @map("documento_hash")
  documentoEnc      String         @map("documento_enc")
  tipoDocumento     TipoDocumento  @map("tipo_documento")
  nombreEnc         String         @map("nombre_enc")
  fechaNacEnc       String         @map("fecha_nac_enc")
  bitacoraIngresoId String         @map("bitacora_ingreso_id")
  fechaIngreso      DateTime       @default(now()) @map("fecha_ingreso")
  fechaEgreso       DateTime?      @map("fecha_egreso")
  estado            EstadoPaciente @default(ACTIVO)
  servicioId        String?        @map("servicio_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt     @map("updated_at")

  bitacoraIngreso Bitacora        @relation(fields: [bitacoraIngresoId], references: [id])
  eventos         EventoPaciente[]

  @@index([documentoHash])
  @@index([estado])
  @@map("pacientes_bitacora")
}

model EventoPaciente {
  id              String           @id @default(cuid())
  pacienteId      String           @map("paciente_id")
  bitacoraId      String           @map("bitacora_id")
  tipoEvento      TipoEvento       @map("tipo_evento")
  detalle         String?
  diasEstancia    Int              @map("dias_estancia")
  registradoPorId Int              @map("registrado_por_id")
  createdAt       DateTime         @default(now()) @map("created_at")

  paciente      PacienteBitacora @relation(fields: [pacienteId], references: [id])
  registradoPor User             @relation(fields: [registradoPorId], references: [id])

  @@index([pacienteId])
  @@index([bitacoraId])
  @@map("eventos_paciente")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum TurnoBitacora {
  MANANA
  TARDE
  NOCHE
  GUARDIA_24
  ESPECIAL
}

enum EstadoBitacora {
  ABIERTA
  CERRADA
}

enum EstadoPaciente {
  ACTIVO
  ALTA
  FALLECIDO
  TRASLADO_INTERNO
  TRASLADO_EXTERNO
  COMPLICACION
}

enum TipoEvento {
  INGRESO
  ALTA
  FALLECIDO
  COMPLICACION
  TRASLADO_INTERNO
  TRASLADO_EXTERNO
}

enum TipoDocumento {
  CEDULA
  PASAPORTE
  CARNET_EXTRANJERIA
  SIN_DOCUMENTO
}

enum RolBitacora {
  INTERNO
  JEFE
  AUDITOR
  ADMIN
}
